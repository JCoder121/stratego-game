{
  "name": "stratego-engine",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:sim": "SIM=1 vitest run test/sim",
    "test:ws": "WS=1 vitest run test/server/integration.test.ts",
    "typecheck": "tsc --noEmit",
    "cli": "tsx src/cli/main.ts",
    "sim": "tsx src/sim/run.ts",
    "sim:full": "tsx src/sim/full.ts",
    "dev:server": "tsx watch src/server/main.ts",
    "dev:web": "vite",
    "build:web": "vite build",
    "serve": "npm run build:web && tsx src/server/main.ts",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^20.14.0",
    "@types/ws": "^8.18.1",
    "fast-check": "^3.19.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.21",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "ws": "^8.21.1"
  }
}
